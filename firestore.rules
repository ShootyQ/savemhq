rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.email == "andrewpcarlson85@gmail.com";
    }

    function isAutoApprovedUser() {
      return isAuthed() && (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        || request.auth.token.email == "savannahbcarlson@gmail.com"
      );
    }

    function isApprovalOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isApprovedUser() {
      return isAuthed()
        && (
          isAutoApprovedUser()
          || (
            exists(/databases/$(database)/documents/loginApprovals/$(request.auth.uid))
            && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.status == "approved"
          )
        );
    }

    function approvalRecordExists() {
      return isAuthed()
        && exists(/databases/$(database)/documents/loginApprovals/$(request.auth.uid));
    }

    function approvalStatusIsApproved() {
      return approvalRecordExists()
        && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.status == "approved";
    }

    function approvalAccessSectionsContain(section) {
      return approvalRecordExists()
        && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.accessSections is list
        && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.accessSections.hasAny([section]);
    }

    function approvalPersonMatches(value) {
      return approvalRecordExists()
        && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.person == value;
    }

    function isApprovedForSection(section) {
      return isAuthed()
        && (
          isAutoApprovedUser()
          || (
            approvalStatusIsApproved()
            && approvalAccessSectionsContain(section)
          )
        );
    }

    function approvalRecordKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "uid",
        "email",
        "status",
        "requestedAt",
        "lastLoginAttemptAt"
      ]) && request.resource.data.keys().hasOnly([
        "uid",
        "email",
        "status",
        "requestedAt",
        "lastLoginAttemptAt",
        "reviewedAt",
        "reviewedBy",
        "person",
        "personLabel",
        "accessSections"
      ])
        && request.resource.data.uid is string
        && request.resource.data.email is string
        && request.resource.data.status is string
        && (!request.resource.data.keys().hasAny(["reviewedBy"]) || request.resource.data.reviewedBy == null || request.resource.data.reviewedBy is string)
        && (!request.resource.data.keys().hasAny(["person"]) || request.resource.data.person == null || request.resource.data.person is string)
        && (!request.resource.data.keys().hasAny(["personLabel"]) || request.resource.data.personLabel == null || request.resource.data.personLabel is string)
        && (!request.resource.data.keys().hasAny(["accessSections"]) || (
          request.resource.data.accessSections is list
          && request.resource.data.accessSections.size() <= 12
        ));
    }

    function requestPersonMatchesAuthedRoadTripLogger() {
      return isApprovedForSection("road-trip")
        && approvalPersonMatches(request.resource.data.person);
    }

    function resourcePersonMatchesAuthedRoadTripLogger() {
      return isApprovedForSection("road-trip")
        && approvalPersonMatches(resource.data.person);
    }

    function roadTripEventKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "eventType",
        "person",
        "personLabel",
        "subject",
        "subjectLabel",
        "content",
        "locationSource",
        "sourcePage",
        "createdAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "eventType",
        "person",
        "personLabel",
        "subject",
        "subjectLabel",
        "content",
        "photoUrl",
        "photoPath",
        "photoUrls",
        "photoPaths",
        "routeLeg",
        "lat",
        "lng",
        "locationSource",
        "sourcePage",
        "createdAt"
      ]) && roadTripEventPhotosAreAllowed();
    }

    function roadTripEventPhotosAreAllowed() {
      return (
        !request.resource.data.keys().hasAny(["photoUrl", "photoPath"])
        || (
          request.resource.data.photoUrl is string
          && request.resource.data.photoPath is string
        )
      ) && (
        !request.resource.data.keys().hasAny(["photoUrls", "photoPaths"])
        || (
          request.resource.data.photoUrls is list
          && request.resource.data.photoPaths is list
          && request.resource.data.photoUrls.size() == request.resource.data.photoPaths.size()
          && request.resource.data.photoUrls.size() <= 3
        )
      );
    }

    function roadTripReactionKeysAreAllowed(uid, eventId) {
      return request.resource.data.keys().hasAll([
        "tripId",
        "eventId",
        "uid",
        "reaction",
        "createdAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "eventId",
        "uid",
        "reaction",
        "createdAt",
        "updatedAt"
      ])
        && request.resource.data.uid == uid
        && request.resource.data.eventId == eventId
        && ["heart", "lol", "shocked"].hasAny([request.resource.data.reaction]);
    }

    function kidsSaidItBingoKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "round",
        "andyCard",
        "savannahCard",
        "andyMarks",
        "savannahMarks",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "round",
        "andyCard",
        "savannahCard",
        "andyMarks",
        "savannahMarks",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]);
    }

    function alphabetGameKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]);
    }

    function scavengerHuntKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "items",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "items",
        "updatedAt"
      ]);
    }

    function requestUploaderMatchesAuthedRoadTripLogger() {
      return isApprovedForSection("road-trip")
        && approvalPersonMatches(request.resource.data.uploaderPerson);
    }

    function resourceUploaderMatchesAuthedRoadTripLogger() {
      return isApprovedForSection("road-trip")
        && approvalPersonMatches(resource.data.uploaderPerson);
    }

    function photoProofEntryKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "challengeId",
        "challengeLabel",
        "caption",
        "photoUrl",
        "photoPath",
        "uploaderPerson",
        "uploaderLabel",
        "sourcePage",
        "createdAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "challengeId",
        "challengeLabel",
        "caption",
        "photoUrl",
        "photoPath",
        "uploaderPerson",
        "uploaderLabel",
        "sourcePage",
        "createdAt",
        "updatedAt"
      ]);
    }

    function photoProofVoteKeysAreAllowed(uid) {
      return request.resource.data.keys().hasAll([
        "tripId",
        "entryId",
        "uid",
        "voterLabel",
        "createdAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "entryId",
        "uid",
        "voterLabel",
        "createdAt"
      ]) && request.resource.data.uid == uid;
    }

    function photoProofEntryOwnerCanManageVotes(tripId, entryId) {
      return isApprovedForSection("road-trip")
        && exists(/databases/$(database)/documents/roadTrips/$(tripId)/photoProofEntries/$(entryId))
        && approvalPersonMatches(get(/databases/$(database)/documents/roadTrips/$(tripId)/photoProofEntries/$(entryId)).data.uploaderPerson);
    }

    function roadTripEventOwnerCanManageReactions(tripId, eventId) {
      return isApprovedForSection("road-trip")
        && exists(/databases/$(database)/documents/roadTrips/$(tripId)/events/$(eventId))
        && approvalPersonMatches(get(/databases/$(database)/documents/roadTrips/$(tripId)/events/$(eventId)).data.person);
    }

    function sharedStatesGameKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "claimedStates",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "claimedStates",
        "updatedAt"
      ]);
    }

    function monthWriteKeysAreAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "month",
        "order",
        "andyStates",
        "savannahStates",
        "updatedAt"
      ]);
    }

    function monthIsUnlocked() {
      return !resource.data.keys().hasAny(["locked"]) || resource.data.locked != true;
    }

    function backyardBirdSpeciesKeysAreAllowed(speciesId) {
      return request.resource.data.keys().hasAll([
        "name",
        "slug",
        "source",
        "createdByUid",
        "createdByLabel",
        "createdAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "name",
        "slug",
        "source",
        "createdByUid",
        "createdByLabel",
        "createdAt",
        "updatedAt"
      ])
        && request.resource.data.slug == speciesId
        && request.resource.data.name is string
        && request.resource.data.slug is string
        && request.resource.data.source is string
        && request.resource.data.createdByUid is string
        && request.resource.data.createdByLabel is string;
    }

    function backyardBirdMonthKeysAreAllowed(monthId) {
      return request.resource.data.keys().hasAll([
        "monthId",
        "label",
        "year",
        "monthNumber",
        "sortOrder",
        "birdIds",
        "birdNames",
        "lastLoggedBirdId",
        "lastLoggedBirdName",
        "lastLoggedByUid",
        "lastLoggedByLabel",
        "updatedAt",
        "lastLoggedAt"
      ]) && request.resource.data.keys().hasOnly([
        "monthId",
        "label",
        "year",
        "monthNumber",
        "sortOrder",
        "birdIds",
        "birdNames",
        "lastLoggedBirdId",
        "lastLoggedBirdName",
        "lastLoggedByUid",
        "lastLoggedByLabel",
        "updatedAt",
        "lastLoggedAt"
      ])
        && request.resource.data.monthId == monthId
        && request.resource.data.label is string
        && request.resource.data.year is int
        && request.resource.data.monthNumber is int
        && request.resource.data.sortOrder is int
        && request.resource.data.birdIds is list
        && request.resource.data.birdNames is list
        && request.resource.data.birdIds.size() <= 300
        && request.resource.data.birdNames.size() <= 300
        && request.resource.data.lastLoggedBirdId is string
        && request.resource.data.lastLoggedBirdName is string
        && request.resource.data.lastLoggedByUid is string
        && request.resource.data.lastLoggedByLabel is string;
    }

    function backyardBirdDayKeysAreAllowed(monthId, dayId) {
      return request.resource.data.keys().hasAll([
        "dayId",
        "monthId",
        "dateKey",
        "label",
        "birdIds",
        "birdNames",
        "lastLoggedBirdId",
        "lastLoggedBirdName",
        "lastLoggedByUid",
        "lastLoggedByLabel",
        "updatedAt",
        "lastLoggedAt"
      ]) && request.resource.data.keys().hasOnly([
        "dayId",
        "monthId",
        "dateKey",
        "label",
        "birdIds",
        "birdNames",
        "lastLoggedBirdId",
        "lastLoggedBirdName",
        "lastLoggedByUid",
        "lastLoggedByLabel",
        "updatedAt",
        "lastLoggedAt"
      ])
        && request.resource.data.dayId == dayId
        && request.resource.data.monthId == monthId
        && request.resource.data.dateKey == dayId
        && request.resource.data.label is string
        && request.resource.data.birdIds is list
        && request.resource.data.birdNames is list
        && request.resource.data.birdIds.size() <= 300
        && request.resource.data.birdNames.size() <= 300
        && request.resource.data.lastLoggedBirdId is string
        && request.resource.data.lastLoggedBirdName is string
        && request.resource.data.lastLoggedByUid is string
        && request.resource.data.lastLoggedByLabel is string;
    }

    function aftercareStatusIsValid(value) {
      return ["checked-in", "checked-out"].hasAny([value]);
    }

    function aftercareStudentKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "displayName",
        "normalizedName",
        "group",
        "isActive",
        "currentStatus",
        "currentAttendanceId",
        "currentCheckInAt",
        "lastActionAt",
        "createdAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "displayName",
        "normalizedName",
        "group",
        "isActive",
        "currentStatus",
        "currentAttendanceId",
        "currentCheckInAt",
        "lastActionAt",
        "createdAt",
        "updatedAt"
      ])
        && request.resource.data.displayName is string
        && request.resource.data.normalizedName is string
        && (request.resource.data.group == null || request.resource.data.group is string)
        && request.resource.data.isActive is bool
        && aftercareStatusIsValid(request.resource.data.currentStatus)
        && (request.resource.data.currentAttendanceId == null || request.resource.data.currentAttendanceId is string);
    }

    function aftercareAttendanceKeysAreAllowed(studentId) {
      return request.resource.data.keys().hasAll([
        "studentId",
        "studentName",
        "studentGroup",
        "dateKey",
        "status",
        "checkedInAt",
        "checkedOutAt",
        "checkedInByUid",
        "checkedInByLabel",
        "checkedOutByUid",
        "checkedOutByLabel",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "studentId",
        "studentName",
        "studentGroup",
        "dateKey",
        "status",
        "checkedInAt",
        "checkedOutAt",
        "checkedInByUid",
        "checkedInByLabel",
        "checkedOutByUid",
        "checkedOutByLabel",
        "updatedAt"
      ])
        && request.resource.data.studentId == studentId
        && request.resource.data.studentName is string
        && (request.resource.data.studentGroup == null || request.resource.data.studentGroup is string)
        && request.resource.data.dateKey is string
        && aftercareStatusIsValid(request.resource.data.status)
        && request.resource.data.checkedInByUid is string
        && request.resource.data.checkedInByLabel is string
        && (request.resource.data.checkedOutByUid == null || request.resource.data.checkedOutByUid is string)
        && (request.resource.data.checkedOutByLabel == null || request.resource.data.checkedOutByLabel is string);
    }

    match /competitions/{year}/months/{month} {
      allow read: if true;
      allow create: if isAdmin() || (
        isApprovedForSection("plates")
        && request.resource.data.keys().hasOnly([
          "month",
          "order",
          "andyStates",
          "savannahStates",
          "updatedAt"
        ])
      );
      allow update: if isAdmin() || (
        isApprovedForSection("plates")
        && monthIsUnlocked()
        && monthWriteKeysAreAllowed()
      );
      allow delete: if isAdmin();
    }

    match /loginApprovals/{uid} {
      allow create: if isAdmin() || (
        isApprovalOwner(uid)
        && approvalRecordKeysAreAllowed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          !request.resource.data.keys().hasAny(["accessSections"])
          || request.resource.data.accessSections == []
        )
        && (
          (
            !isAutoApprovedUser()
            && request.resource.data.status == "pending"
            && !request.resource.data.keys().hasAny(["person", "personLabel"])
            && request.resource.data.reviewedAt == null
            && request.resource.data.reviewedBy == null
          ) || (
            isAutoApprovedUser()
            && request.resource.data.status == "approved"
            && request.resource.data.reviewedBy == request.auth.token.email
          )
        )
      );

      allow read: if isAdmin() || isApprovalOwner(uid);

      allow update: if isAdmin() || (
        isApprovalOwner(uid)
        && approvalRecordKeysAreAllowed()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.requestedAt == resource.data.requestedAt
        && request.resource.data.person == resource.data.person
        && request.resource.data.personLabel == resource.data.personLabel
        && request.resource.data.accessSections == resource.data.accessSections
        && request.resource.data.status == resource.data.status
        && request.resource.data.reviewedAt == resource.data.reviewedAt
        && request.resource.data.reviewedBy == resource.data.reviewedBy
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "email",
          "lastLoginAttemptAt"
        ])
      ) || (
        isApprovalOwner(uid)
        && isAutoApprovedUser()
        && approvalRecordKeysAreAllowed()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.requestedAt == resource.data.requestedAt
        && request.resource.data.person == resource.data.person
        && request.resource.data.personLabel == resource.data.personLabel
        && request.resource.data.accessSections == resource.data.accessSections
        && resource.data.status != "approved"
        && request.resource.data.status == "approved"
        && request.resource.data.reviewedBy == request.auth.token.email
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "email",
          "lastLoginAttemptAt",
          "status",
          "reviewedAt",
          "reviewedBy"
        ])
      );

      allow delete: if isAdmin();
    }

    match /roadTrips/{tripId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roadTrips/{tripId}/events/{eventId} {
      allow read: if true;
      allow create: if isApprovedForSection("road-trip")
        && roadTripEventKeysAreAllowed()
        && requestPersonMatchesAuthedRoadTripLogger()
        && request.resource.data.tripId == tripId;
      allow update: if false;
      allow delete: if isAdmin() || (
        isApprovedForSection("road-trip")
        && resource.data.tripId == tripId
        && resourcePersonMatchesAuthedRoadTripLogger()
      );
    }

    match /roadTrips/{tripId}/events/{eventId}/reactions/{uid} {
      allow read: if true;
      allow create, update: if request.resource.data.tripId == tripId
        && roadTripReactionKeysAreAllowed(uid, eventId);
      allow delete: if isAdmin() || roadTripEventOwnerCanManageReactions(tripId, eventId);
    }

    match /roadTrips/{tripId}/photoProofEntries/{entryId} {
      allow read: if true;
      allow create: if isApprovedForSection("road-trip")
        && photoProofEntryKeysAreAllowed()
        && request.resource.data.tripId == tripId
        && [
          "weirdest-gas-station-snack",
          "funniest-sign",
          "sketchiest-mascot",
          "best-sunset",
          "best-moments",
          "strangest-town-name"
        ].hasAny([request.resource.data.challengeId])
        && ["andy", "savannah"].hasAny([request.resource.data.uploaderPerson])
        && requestUploaderMatchesAuthedRoadTripLogger();
      allow update: if false;
      allow delete: if isAdmin() || (
        isApprovedForSection("road-trip")
        && resource.data.tripId == tripId
        && resourceUploaderMatchesAuthedRoadTripLogger()
      );
    }

    match /roadTrips/{tripId}/photoProofEntries/{entryId}/votes/{uid} {
      allow read: if true;
      allow create: if request.resource.data.uid == uid
        && request.resource.data.tripId == tripId
        && request.resource.data.entryId == entryId
        && photoProofVoteKeysAreAllowed(uid);
      allow update: if false;
      allow delete: if isAdmin() || photoProofEntryOwnerCanManageVotes(tripId, entryId);
    }

    match /roadTrips/{tripId}/games/{gameId} {
      allow read: if true;
      allow create, update: if isApprovedForSection("road-trip")
        && request.resource.data.tripId == tripId
        && request.resource.data.gameId == gameId
        && (
          (
            gameId == "kids-said-it-bingo"
            && request.resource.data.title == "Kid's Said It Bingo"
            && kidsSaidItBingoKeysAreAllowed()
          ) || (
            gameId == "alphabet-game"
            && request.resource.data.title == "Alphabet Game"
            && alphabetGameKeysAreAllowed()
          ) || (
            gameId == "road-trip-scavenger-hunt"
            && request.resource.data.title == "Road Trip Scavenger Hunt"
            && scavengerHuntKeysAreAllowed()
          ) || (
            gameId == "shared-states-game"
            && request.resource.data.title == "Shared States Game"
            && sharedStatesGameKeysAreAllowed()
          )
        );
      allow delete: if isAdmin();
    }

    match /backyardBirds/{trackerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /backyardBirds/{trackerId}/species/{speciesId} {
      allow read: if true;
      allow create, update: if isApprovedForSection("birds")
        && backyardBirdSpeciesKeysAreAllowed(speciesId);
      allow delete: if isAdmin();
    }

    match /backyardBirds/{trackerId}/months/{monthId} {
      allow read: if true;
      allow create, update: if isApprovedForSection("birds")
        && backyardBirdMonthKeysAreAllowed(monthId);
      allow delete: if isAdmin();
    }

    match /backyardBirds/{trackerId}/months/{monthId}/days/{dayId} {
      allow read: if true;
      allow create, update: if isApprovedForSection("birds")
        && backyardBirdDayKeysAreAllowed(monthId, dayId);
      allow delete: if isAdmin();
    }

    match /aftercarePrograms/{programId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /aftercarePrograms/{programId}/students/{studentId} {
      allow read: if isAdmin() || isApprovedForSection("aftercare");
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isApprovedForSection("aftercare")
        && aftercareStudentKeysAreAllowed()
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.normalizedName == resource.data.normalizedName
        && request.resource.data.group == resource.data.group
        && request.resource.data.isActive == resource.data.isActive
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "currentStatus",
          "currentAttendanceId",
          "currentCheckInAt",
          "lastActionAt",
          "updatedAt"
        ])
      );
    }

    match /aftercarePrograms/{programId}/attendance/{attendanceId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || (
        isApprovedForSection("aftercare")
        && aftercareAttendanceKeysAreAllowed(request.resource.data.studentId)
        && request.resource.data.status == "checked-in"
        && request.resource.data.checkedOutAt == null
        && request.resource.data.checkedOutByUid == null
        && request.resource.data.checkedOutByLabel == null
      );
      allow update: if isAdmin() || (
        isApprovedForSection("aftercare")
        && aftercareAttendanceKeysAreAllowed(resource.data.studentId)
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.studentName == resource.data.studentName
        && request.resource.data.studentGroup == resource.data.studentGroup
        && request.resource.data.dateKey == resource.data.dateKey
        && request.resource.data.checkedInAt == resource.data.checkedInAt
        && request.resource.data.checkedInByUid == resource.data.checkedInByUid
        && request.resource.data.checkedInByLabel == resource.data.checkedInByLabel
        && resource.data.status == "checked-in"
        && resource.data.checkedOutAt == null
        && request.resource.data.status == "checked-out"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "checkedOutAt",
          "checkedOutByUid",
          "checkedOutByLabel",
          "updatedAt"
        ])
      );
      allow delete: if isAdmin();
    }
  }
}
