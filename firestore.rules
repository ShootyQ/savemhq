rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.email == "andrewpcarlson85@gmail.com";
    }

    function isAutoApprovedUser() {
      return isAuthed() && (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        || request.auth.token.email == "savannahbcarlson@gmail.com"
      );
    }

    function isApprovalOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isApprovedUser() {
      return isAuthed()
        && (
          isAutoApprovedUser()
          || (
            exists(/databases/$(database)/documents/loginApprovals/$(request.auth.uid))
            && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.status == "approved"
          )
        );
    }

    function requestPersonMatchesAuthedRoadTripLogger() {
      return (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        && request.resource.data.person == "andy"
      ) || (
        request.auth.token.email == "savannahbcarlson@gmail.com"
        && request.resource.data.person == "savannah"
      );
    }

    function roadTripEventKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "eventType",
        "person",
        "personLabel",
        "subject",
        "subjectLabel",
        "content",
        "locationSource",
        "sourcePage",
        "createdAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "eventType",
        "person",
        "personLabel",
        "subject",
        "subjectLabel",
        "content",
        "routeLeg",
        "lat",
        "lng",
        "locationSource",
        "sourcePage",
        "createdAt"
      ]);
    }

    function monthWriteKeysAreAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "month",
        "order",
        "andyStates",
        "savannahStates",
        "updatedAt"
      ]);
    }

    function monthIsUnlocked() {
      return !resource.data.keys().hasAny(["locked"]) || resource.data.locked != true;
    }

    match /competitions/{year}/months/{month} {
      allow read: if true;
      allow create: if isAdmin() || (
        isApprovedUser()
        && request.resource.data.keys().hasOnly([
          "month",
          "order",
          "andyStates",
          "savannahStates",
          "updatedAt"
        ])
      );
      allow update: if isAdmin() || (
        isApprovedUser()
        && monthIsUnlocked()
        && monthWriteKeysAreAllowed()
      );
      allow delete: if isAdmin();
    }

    match /loginApprovals/{uid} {
      allow create: if isApprovalOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && (
          request.resource.data.status == "pending"
          || (
            isAutoApprovedUser()
            && request.resource.data.status == "approved"
            && request.resource.data.reviewedBy == request.auth.token.email
          )
        );

      allow read: if isAdmin() || isApprovalOwner(uid);

      allow update: if isAdmin() || (
        isApprovalOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.status == resource.data.status
      ) || (
        isApprovalOwner(uid)
        && isAutoApprovedUser()
        && request.resource.data.uid == resource.data.uid
        && resource.data.status != "approved"
        && request.resource.data.status == "approved"
        && request.resource.data.reviewedBy == request.auth.token.email
      );

      allow delete: if isAdmin();
    }

    match /roadTrips/{tripId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roadTrips/{tripId}/events/{eventId} {
      allow read: if true;
      allow create: if isAutoApprovedUser()
        && roadTripEventKeysAreAllowed()
        && requestPersonMatchesAuthedRoadTripLogger()
        && request.resource.data.tripId == tripId;
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
