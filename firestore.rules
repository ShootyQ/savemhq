rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.email == "andrewpcarlson85@gmail.com";
    }

    function isAutoApprovedUser() {
      return isAuthed() && (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        || request.auth.token.email == "savannahbcarlson@gmail.com"
      );
    }

    function isApprovalOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isApprovedUser() {
      return isAuthed()
        && (
          isAutoApprovedUser()
          || (
            exists(/databases/$(database)/documents/loginApprovals/$(request.auth.uid))
            && get(/databases/$(database)/documents/loginApprovals/$(request.auth.uid)).data.status == "approved"
          )
        );
    }

    function requestPersonMatchesAuthedRoadTripLogger() {
      return (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        && request.resource.data.person == "andy"
      ) || (
        request.auth.token.email == "savannahbcarlson@gmail.com"
        && request.resource.data.person == "savannah"
      );
    }

    function resourcePersonMatchesAuthedRoadTripLogger() {
      return (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        && resource.data.person == "andy"
      ) || (
        request.auth.token.email == "savannahbcarlson@gmail.com"
        && resource.data.person == "savannah"
      );
    }

    function roadTripEventKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "eventType",
        "person",
        "personLabel",
        "subject",
        "subjectLabel",
        "content",
        "locationSource",
        "sourcePage",
        "createdAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "eventType",
        "person",
        "personLabel",
        "subject",
        "subjectLabel",
        "content",
        "photoUrl",
        "photoPath",
        "routeLeg",
        "lat",
        "lng",
        "locationSource",
        "sourcePage",
        "createdAt"
      ]);
    }

    function kidsSaidItBingoKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "round",
        "andyCard",
        "savannahCard",
        "andyMarks",
        "savannahMarks",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "round",
        "andyCard",
        "savannahCard",
        "andyMarks",
        "savannahMarks",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]);
    }

    function alphabetGameKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "andyWins",
        "savannahWins",
        "lastWinner",
        "lastWinnerLabel",
        "lastWonAt",
        "updatedAt"
      ]);
    }

    function scavengerHuntKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "items",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "items",
        "updatedAt"
      ]);
    }

    function requestUploaderMatchesAuthedRoadTripLogger() {
      return (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        && request.resource.data.uploaderPerson == "andy"
      ) || (
        request.auth.token.email == "savannahbcarlson@gmail.com"
        && request.resource.data.uploaderPerson == "savannah"
      );
    }

    function resourceUploaderMatchesAuthedRoadTripLogger() {
      return (
        request.auth.token.email == "andrewpcarlson85@gmail.com"
        && resource.data.uploaderPerson == "andy"
      ) || (
        request.auth.token.email == "savannahbcarlson@gmail.com"
        && resource.data.uploaderPerson == "savannah"
      );
    }

    function photoProofEntryKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "challengeId",
        "challengeLabel",
        "caption",
        "photoUrl",
        "photoPath",
        "uploaderPerson",
        "uploaderLabel",
        "sourcePage",
        "createdAt",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "challengeId",
        "challengeLabel",
        "caption",
        "photoUrl",
        "photoPath",
        "uploaderPerson",
        "uploaderLabel",
        "sourcePage",
        "createdAt",
        "updatedAt"
      ]);
    }

    function photoProofVoteKeysAreAllowed(uid) {
      return request.resource.data.keys().hasAll([
        "tripId",
        "entryId",
        "uid",
        "voterLabel",
        "createdAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "entryId",
        "uid",
        "voterLabel",
        "createdAt"
      ]) && request.resource.data.uid == uid;
    }

    function photoProofEntryOwnerCanManageVotes(tripId, entryId) {
      return isAutoApprovedUser()
        && exists(/databases/$(database)/documents/roadTrips/$(tripId)/photoProofEntries/$(entryId))
        && (
          (
            request.auth.token.email == "andrewpcarlson85@gmail.com"
            && get(/databases/$(database)/documents/roadTrips/$(tripId)/photoProofEntries/$(entryId)).data.uploaderPerson == "andy"
          ) || (
            request.auth.token.email == "savannahbcarlson@gmail.com"
            && get(/databases/$(database)/documents/roadTrips/$(tripId)/photoProofEntries/$(entryId)).data.uploaderPerson == "savannah"
          )
        );
    }

    function sharedStatesGameKeysAreAllowed() {
      return request.resource.data.keys().hasAll([
        "tripId",
        "gameId",
        "title",
        "claimedStates",
        "updatedAt"
      ]) && request.resource.data.keys().hasOnly([
        "tripId",
        "gameId",
        "title",
        "claimedStates",
        "updatedAt"
      ]);
    }

    function monthWriteKeysAreAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "month",
        "order",
        "andyStates",
        "savannahStates",
        "updatedAt"
      ]);
    }

    function monthIsUnlocked() {
      return !resource.data.keys().hasAny(["locked"]) || resource.data.locked != true;
    }

    match /competitions/{year}/months/{month} {
      allow read: if true;
      allow create: if isAdmin() || (
        isApprovedUser()
        && request.resource.data.keys().hasOnly([
          "month",
          "order",
          "andyStates",
          "savannahStates",
          "updatedAt"
        ])
      );
      allow update: if isAdmin() || (
        isApprovedUser()
        && monthIsUnlocked()
        && monthWriteKeysAreAllowed()
      );
      allow delete: if isAdmin();
    }

    match /loginApprovals/{uid} {
      allow create: if isApprovalOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && (
          request.resource.data.status == "pending"
          || (
            isAutoApprovedUser()
            && request.resource.data.status == "approved"
            && request.resource.data.reviewedBy == request.auth.token.email
          )
        );

      allow read: if isAdmin() || isApprovalOwner(uid);

      allow update: if isAdmin() || (
        isApprovalOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.status == resource.data.status
      ) || (
        isApprovalOwner(uid)
        && isAutoApprovedUser()
        && request.resource.data.uid == resource.data.uid
        && resource.data.status != "approved"
        && request.resource.data.status == "approved"
        && request.resource.data.reviewedBy == request.auth.token.email
      );

      allow delete: if isAdmin();
    }

    match /roadTrips/{tripId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roadTrips/{tripId}/events/{eventId} {
      allow read: if true;
      allow create: if isAutoApprovedUser()
        && roadTripEventKeysAreAllowed()
        && requestPersonMatchesAuthedRoadTripLogger()
        && request.resource.data.tripId == tripId;
      allow update: if false;
      allow delete: if isAdmin() || (
        isAutoApprovedUser()
        && resource.data.tripId == tripId
        && resourcePersonMatchesAuthedRoadTripLogger()
      );
    }

    match /roadTrips/{tripId}/photoProofEntries/{entryId} {
      allow read: if true;
      allow create: if isAutoApprovedUser()
        && photoProofEntryKeysAreAllowed()
        && request.resource.data.tripId == tripId
        && [
          "weirdest-gas-station-snack",
          "funniest-sign",
          "sketchiest-mascot",
          "best-sunset",
          "best-moments",
          "strangest-town-name"
        ].hasAny([request.resource.data.challengeId])
        && ["andy", "savannah"].hasAny([request.resource.data.uploaderPerson])
        && requestUploaderMatchesAuthedRoadTripLogger();
      allow update: if false;
      allow delete: if isAdmin() || (
        isAutoApprovedUser()
        && resource.data.tripId == tripId
        && resourceUploaderMatchesAuthedRoadTripLogger()
      );
    }

    match /roadTrips/{tripId}/photoProofEntries/{entryId}/votes/{uid} {
      allow read: if true;
      allow create: if isApprovedUser()
        && request.auth.uid == uid
        && request.resource.data.tripId == tripId
        && request.resource.data.entryId == entryId
        && photoProofVoteKeysAreAllowed(uid);
      allow update: if false;
      allow delete: if isAdmin() || (
        isApprovedUser()
        && request.auth.uid == uid
      ) || photoProofEntryOwnerCanManageVotes(tripId, entryId);
    }

    match /roadTrips/{tripId}/games/{gameId} {
      allow read: if true;
      allow create, update: if isAutoApprovedUser()
        && request.resource.data.tripId == tripId
        && request.resource.data.gameId == gameId
        && (
          (
            gameId == "kids-said-it-bingo"
            && request.resource.data.title == "Kid's Said It Bingo"
            && kidsSaidItBingoKeysAreAllowed()
          ) || (
            gameId == "alphabet-game"
            && request.resource.data.title == "Alphabet Game"
            && alphabetGameKeysAreAllowed()
          ) || (
            gameId == "road-trip-scavenger-hunt"
            && request.resource.data.title == "Road Trip Scavenger Hunt"
            && scavengerHuntKeysAreAllowed()
          ) || (
            gameId == "shared-states-game"
            && request.resource.data.title == "Shared States Game"
            && sharedStatesGameKeysAreAllowed()
          )
        );
      allow delete: if isAdmin();
    }
  }
}
